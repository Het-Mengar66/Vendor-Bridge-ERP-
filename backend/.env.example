# Supabase Configuration
# You will get these values from the Supabase Dashboard -> Project Settings -> API / Database

# FastAPI (Backend) env vars
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_KEY="your-anon-or-service-role-key"
DATABASE_URL="postgresql://postgres.[your-project-id]:[your-password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"

# Optional: Add other environment variables here later
